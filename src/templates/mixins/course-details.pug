mixin courseDetails(niche)
    -
        const currency = pricing.currency.short;
        const firstCoursePrice = `${pricing.courses["4packs"].finalPrice}${currency}`
        const secondCoursePrice = `${pricing.courses["6packs"].finalPrice}${currency}`

        const images = {
            'joints': {
                kit: {
                    src: 'img/kit-joints.png',
                },
                firstProduct: {
                    pack: 'img/steplex-pack.png',
                },
                secondProduct: {
                    pack: 'img/cardiform-pack.png',
                    horizontal: true
                },
                plans: {
                    vertical: true
                }
            },
            'diabetes': {
                kit: {
                    src: 'img/kit-diabetes.png',
                },
                firstProduct: {
                    pack: 'img/inspicure-pack.png',
                },
                secondProduct: {
                    pack: 'img/guavital-pack.png',
                }
            },
            'blood-pressure': {
                kit: {
                    src: 'img/kit-blood-pressure.png',
                },
                firstProduct: {
                    pack: 'img/tonerin-pack.png',
                },
                secondProduct: {
                    pack: 'img/ultraxal-pack.png',
                }
            },
            'weight-loss': {
                kit: {
                    src: 'img/kit-weight-loss.png',
                },
                firstProduct: {
                    pack: 'img/slimital-pack.png',
                },
                secondProduct: {
                    pack: 'img/ultraxal-pack.png',
                }
            },
            'tiredness': {
                kit: {
                    src: 'img/kit-tiredness.png',
                },
                firstProduct: {
                    pack: 'img/vermixin-pack.png',
                    horizontal: true
                },
                secondProduct: {
                    pack: 'img/slimital-pack.png',
                },
                plans: {
                    vertical: true
                }
            }
        };

        // Get localized content for this niche
        const content = t.courseDetails && t.courseDetails[niche] ? t.courseDetails[niche] : null;
        const enContent = tEn.courseDetails && tEn.courseDetails[niche] ? tEn.courseDetails[niche] : null;


    //.course-details.hidden(data-niche=niche)
    .course-details(data-niche=niche)
        // Determine if firstProduct is horizontal
        - const isFirstProductHorizontal = images[niche] && images[niche].firstProduct && images[niche].firstProduct.horizontal === true;
        // Determine if secondProduct is horizontal
        - const isSecondProductHorizontal = images[niche] && images[niche].secondProduct && images[niche].secondProduct.horizontal === true;

        if content
            section.course-kit.course-details__section
                .container.block
                    h2.course-kit__title.text-gold-fill= content.kit.title

                    //.course-kit__products
                    //    .course-kit__products-pack
                    //        source(srcset=basePath + images[niche].kit.src.replace(".png", ".webp") type="image/webp")
                    //        img.course-kit__products-image(src=basePath + images[niche].kit.src alt="Product kit")
                    .course-kit__content
                        .course-kit__products-pack
                            source(srcset=basePath + images[niche].kit.src.replace(".png", ".webp") type="image/webp")
                            img.course-kit__products-image(src=basePath + images[niche].kit.src alt="Product kit")

                        .course-kit__text
                            h3.course-kit__subtitle= content.kit.subtitle
                            p.course-kit__description= content.kit.description


            section.course-product.course-details__section
                .container.course-product__wrapper.block
                    .course-product__pack(class=isFirstProductHorizontal ? 'course-product__pack--horizontal' : '')
                        source(srcset=basePath + images[niche].firstProduct.pack.replace(".png", ".webp") type="image/webp")
                        img.course-product__pack-image(src=basePath + images[niche].firstProduct.pack alt="Product")

                    .components.course-product__components
                        //h3.components__title.text-gold-fill= content.firstProduct.title
                        p.course-product__products-description= content.firstProduct.description
                        ul.components__inner
                            each component in content.firstProduct.components
                                li.components__item
                                    .components__icon
                                        source(srcset=basePath + component.icon.replace(".png", ".webp") type="image/webp")
                                        img.components__icon-image(src=basePath + component.icon alt="Component")
                                    p.components__description
                                        b= component.name
                                        |
                                        | — #{component.description}

            section.course-product.course-product--reversed.course-details__section.course-details__section--no-border
                .container.course-product__wrapper.block
                    .course-product__pack(class=isSecondProductHorizontal ? 'course-product__pack--horizontal' : '')
                        source(srcset=basePath + images[niche].secondProduct.pack.replace(".png", ".webp") type="image/webp")
                        img.course-product__pack-image(src=basePath + images[niche].secondProduct.pack alt="Product")

                    .components.course-product__components
                        //h3.components__title.text-gold-fill= content.secondProduct.title
                        p.course-product__products-description= content.secondProduct.description
                        ul.components__inner
                            each component in content.secondProduct.components
                                li.components__item
                                    .components__icon
                                        source(srcset=basePath + component.icon.replace(".png", ".webp") type="image/webp")
                                        img.components__icon-image(src=basePath + component.icon alt="Component")
                                    p.components__description
                                        b= component.name
                                        |
                                        | — #{component.description}

            section.course-banner.course-details__section.course-details__section--no-border
                .container
                    h2.course-banner__title= content.banner.title
                    a.course-banner__button.intro__btn(href=`#plans-${niche}`)= content.banner.buttonText

            section.course-reviews.course-details__section
                .container.block
                    +reviews(niche)

            section.course-plans.course-details__section
                .container.block
                    .plans(id=`plans-${niche}`)
                        each plan, planIndex in content.plans
                            .plan(class=plan.selected ? 'plan--selected' : '')
                                if plan.label
                                    span.plan__label= plan.label

                                .plan__top
                                    h3.plan__title= plan.title
                                    p.plan__description= plan.description

                                    .plan__products(class=images[niche].plans && images[niche].plans.vertical ? 'plan__products--vertical' : '')
                                        .plan__products-pack
                                            source(srcset=basePath + `img/${niche}-plan-${plan.selected ? '2' : '1'}.png`.replace(".png", ".webp") type="image/webp")
                                            img.plan__products-image(src=basePath + `img/${niche}-plan-${plan.selected ? '2' : '1'}.png` alt="Plan")
                                        .plan__products-label
                                            .plan__products-title= plan.percentage
                                            .plan__products-text= plan.saving

                                    ul.plan-list
                                        li.plan-list__item= plan.packs
                                        li.plan-list__item= plan.duration

                                .plan-price
                                    p.plan-price__title= plan.priceTitle
                                    .plan-price__inner
                                        p.plan-price__value= plan.selected ? secondCoursePrice : firstCoursePrice
                                        p.plan-price__text!= plan.pricePacks
                                    p.plan-price__note= plan.priceDescription

                                .plan__bottom
                                    button.plan__button.course__select.course__select--order.btn.btn-arrow.btn-arrow--right.btn-arrow--double(
                                        type="button"
                                        data-course=plan.selected ? "6" : "4"
                                        data-target-screen="screen-order"
                                        data-price=plan.selected ? secondCoursePrice : firstCoursePrice
                                        data-plan=enContent.plans[planIndex].title
                                    )!= plan.buttonText

            .course-controls
                .container.block
                    button.course-controls__button.btn.btn-arrow.btn-arrow--left(
                        type="button"
                        id="from-course-to-problems"
                        data-target-screen="screen-problems"
                    )!= t.common.actions.selectAnotherProblem
        else
            //- Fallback for niches without localization data yet
            p Content for #{niche} is not available yet
