//section.problems.block(class="screen" id="screen-problems")
section.problems.block(class="screen hidden" id="screen-problems")
    .container
        h2.problems__title= t.problems.title

        ul.problems-list
            li.problems-list__item(data-niche="joints" data-target-screen="screen-course")
                .problems-list__icon
                    img(src=basePath + "img/problems-joints.svg" alt="")
                p.problems-list__text Покращити здоров'я суглобів та кісток
            li.problems-list__item(data-niche="diabetes" data-target-screen="screen-course")
                .problems-list__icon
                    img(src=basePath + "img/problems-diabetes.svg" alt="")
                p.problems-list__text Контролювати рівень цукру в крові
            li.problems-list__item(data-niche="blood-pressure" data-target-screen="screen-course")
                .problems-list__icon
                    img(src=basePath + "img/problems-pressure.svg" alt="")
                p.problems-list__text Сприяти нормалізації тиску
            li.problems-list__item(data-niche="weight-loss" data-target-screen="screen-course")
                .problems-list__icon
                    img(src=basePath + "img/problems-weight.svg" alt="")
                p.problems-list__text Покращити метаболізм та фігуру
            li.problems-list__item(data-niche="tiredness" data-target-screen="screen-course")
                .problems-list__icon
                    img(src=basePath + "img/problems-tiredness.svg" alt="")
                p.problems-list__text Збільшити прилив сил

