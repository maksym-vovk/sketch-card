-
    const courseStatic = [
        {value: "complex1", checked: true, badge: "You save 80 euros!", img: "img/products-group.png"},
        {value: "complex2", checked: false, badge: "You save 80 euros!", img: "img/products-group.png"}
    ]

    const courseConfig = [
        {
            packs: 4,
            niches: {
                "joints": {
                    elements: []
                },
                "diabetes": {
                    elements: []
                },
                "blood-pressure": {
                    elements: []
                },
                "weight-loss": {
                    elements: []
                },
                "tiredness": {
                    elements: []
                },
                "parasites": {
                    elements: []
                },
            }
        }
    ]



section.course.block(class="screen hidden" id="screen-course")
    .container
        .course-modal
            h2.course__title!= t.course.title

            .course-options
                each option, index in t.course.options
                    - const staticOption = courseStatic[index]
                    label.course-option
                        input(
                            type="radio"
                            name="course"
                            value=staticOption.value
                            checked=staticOption.checked
                        )
                        .option-content
                            .badge= staticOption.badge
                            .products
                                img(src=basePath + staticOption.img alt="Комплекси продуктів")
                            .price= option.price
                            .subtitle= option.subtitle
                            ul
                                each item in option.productsList
                                    li= item
                            button.course__details.btn(
                                type="button"
                                id="from-course-to-presentations"
                                data-target-screen="screen-presentations"
                            )= 'Детальніше'
                            //)= t.course.btnSelect
                            button.course__select.btn(
                                type="button"
                                id="from-course-to-order-form"
                                data-target-screen="screen-order"
                            )= 'Замовити'
                            //)= t.course.btnSelect

            button.course__problems.btn(
                type="button"
                id="from-course-to-problems"
                data-target-screen="screen-problems"
            )= 'Обрати іншу проблему'